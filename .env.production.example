# === Database (Supabase) ===
# Paste the full Supabase connection URL (transaction pooler recommended).
# sslmode=require is appended automatically if not present in the URL.
DB_URL=postgresql://user:password@host:port/dbname

# === JWT ===
JWT_SECRET=CHANGE_ME_random_64_char_string
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=720h

# === Google OAuth ===
# GOOGLE_REDIRECT_URL must match Google Console exactly.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=https://api.your-subdomain.yourdomain.com/api/v1/auth/google/callback

# === AWS KMS (optional — falls back to local encryption) ===
# AWS_REGION must match the region of your KMS key ARN.
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === Frontend URL (for CORS + OAuth redirects) ===
# This is the origin where your frontend is deployed (e.g. Vercel).
# Backend CORS allows only this origin. After Google login, backend
# redirects to FRONTEND_URL/auth/callback with tokens.
FRONTEND_URL=https://your-frontend-domain.com

# === Razorpay (optional — leave empty to disable billing) ===
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_TEAM=

# === Backend host port ===
# The port exposed on the EC2 host. Host Nginx proxies to this.
HOST_PORT=8080
