# Server Configuration
PORT=8080
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=envo
DB_PASSWORD=your_password_here
DB_NAME=envo_db
DB_SSLMODE=disable

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=720h

# Google OAuth - copy the redirect_uri printed at server startup into Google Console (no trailing slash)
# In Console: APIs & Services → Credentials → your OAuth client → Authorized redirect URIs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://127.0.0.1:8080/api/v1/auth/google/callback

# AWS KMS
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=your_kms_key_id
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Razorpay (optional — subscriptions + Standard Web Checkout; leave empty to disable billing routes)
# Use test keys from the Razorpay Dashboard. Never commit real secrets.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (subscriptions webhook at POST /api/v1/billing/webhook)
RAZORPAY_WEBHOOK_SECRET=
# Plan IDs for subscription checkout (Standard Checkout uses /billing/orders only)
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_TEAM=

# Team invitation email (optional; falls back to log sender if empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Envo
INVITE_TOKEN_TTL_HOURS=168
